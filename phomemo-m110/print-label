#!/bin/sh
# Print a label image to the Phomemo M110 over USB.
# Usage: print-label <image.png|image.svg> [extra args for phomemo_m110_print.py]
#   e.g. print-label label.png                       (40x30 defaults: align right, speed 2, density 2)
#        print-label label.svg --width 50 --height 30 (Expanded size)
#        print-label label.png --xoff 10              (nudge right 10 dots / ~1.25mm)
#        print-label label.png --density 4            (darker, if a label looks faint)
set -e
[ -n "$1" ] || { echo "usage: print-label <image> [opts]"; exit 1; }
IMG="$1"; shift

# locate the converter next to this script, regardless of cwd / symlink
DIR=$(cd "$(dirname "$(readlink -f "$0")")" && pwd)
CONV="$DIR/phomemo_m110_print.py"

BIN=/tmp/label_m110.bin
PREVIEW=/tmp/label_preview.png
DEV=/dev/usb/lp0

python3 "$CONV" "$IMG" -o "$BIN" --preview "$PREVIEW" "$@"

# Write with a timeout: a sleeping/off M110 accepts no data and the write blocks
# forever, wedging /dev/usb/lp0 for everyone. Fail fast instead. (dd is the writer
# process so `timeout` can actually kill it.)
st=0
if [ -w "$DEV" ]; then
    timeout 20 dd if="$BIN" of="$DEV" bs=64k status=none || st=$?
else
    [ -x /tmp/askpass.sh ] || printf '#!/bin/sh\nexec zenity --password --title="sudo: Phomemo M110"\n' > /tmp/askpass.sh
    chmod +x /tmp/askpass.sh
    SUDO_ASKPASS=/tmp/askpass.sh sudo -A timeout 20 dd if="$BIN" of="$DEV" bs=64k status=none || st=$?
fi

if [ "$st" -eq 124 ]; then
    echo "ERROR: write to $DEV timed out — is the M110 powered on with a steady LED? It auto-sleeps; press its power button and retry." >&2
    exit 1
elif [ "$st" -ne 0 ]; then
    echo "ERROR: failed writing to $DEV (exit $st)." >&2
    exit 1
fi
echo "printed: $IMG  (preview: $PREVIEW)"
